@article{gaogui2026belief,
  bibtex_show = {true},
  title       = {Belief-Space Web Agents via Trajectory Divergence and Adaptive Preference Elicitation},
  author      = {Gao, Gui},
  abstract    = {This proposal introduces Belief-Space Web Agents, a probabilistic approach to web automation that reasons over multiple execution trajectories rather than committing to a single path. By maintaining and updating a belief distribution over candidate actions, the framework explicitly models uncertainty arising from ambiguous instructions and latent user preferences. Adaptive preference elicitation is triggered through trajectory divergence, enabling efficient clarification and globally consistent belief updates. The proposed framework integrates probabilistic inference, decision-making, and human-agent interaction to support more robust and preference-aware web agents.},
  volume      = {16},
  year        = {2026},
  additional_info = {Developed through discussions with Prof. [Tan Zhi Xuan](https://scholar.google.com/citations?user=Yscjyf8AAAAJ&hl=en)},
  preview      = {belief.png}
}

@article{gaogui2026causal,
  bibtex_show = {true},
  title       = {Causal Concept Bottleneck Models: Bayesian Discovery of Causally Relevant Concepts with LLM Priors},
  author      = {Gao, Gui},
  abstract    = {This work proposes Causal BC-LLM, a framework that combines Bayesian concept bottleneck models with causal inference to identify concepts that are not only interpretable but also causally relevant to prediction outcomes. Rather than relying on Large Language Models for causal reasoning, the framework restricts LLMs to concept generation and annotation, while incorporating causal validity directly into Bayesian concept selection through causal structure priors. By favoring concepts within the Markov boundary of the outcome, the proposed approach aims to discover actionable concepts that support intervention and decision-making, improving both interpretability and causal reliability in high-stakes domains such as healthcare and policy.},
  volume      = {10},
  additional_info = {Developed through discussions with Prof. [Tan Yan Shuo](https://scholar.google.com/citations?user=iZY2OUcAAAAJ&hl=en)},
  year        = {2026}
}

@article{gaogui2025bayesian,
  bibtex_show = {true},
  title       = {A Bayesian Multi-Agent System for Scalable and Adaptive Generative AI},
  author      = {Gao, Gui},
  abstract    = {This proposal presents a Bayesian Multi-Agent System (BMAS) for coordinating generative AI agents without centralized control. Each agent maintains belief networks over peers' capabilities and collaboration effectiveness, allowing it to decide independently whether to handle a task or delegate it to a better-suited collaborator. Rather than relying on a fixed architecture, BMAS evolves over time: specialist agents are added as new task types emerge, while redundant agents are pruned using Markov Random Field stability criteria. The framework comes with theoretical guarantees on coordination stability, belief convergence, and complexity overhead, and will be evaluated on mathematical reasoning and financial reporting tasks—testing whether statistical grounding can resolve coordination failures that plague existing multi-agent LLM systems.},
  volume      = {42},
  year        = {2025},
  additional_info = {Developed through discussions with Dr. [Sanju Menon](https://www.linkedin.com/in/sanjumenonp/)},

  preview      = {bayesian.png}
}

@article{gaogui2025game,
  bibtex_show = {true},
  title       = {A Game-Theoretic Bayesian Framework for Adaptive Multi-Agent Generative AI},
  author      = {Gao, Gui},
  abstract    = {Generative AI has achieved significant progress across domains, yet its integration within multi-agent systems remains challenging, as existing frameworks often rely on rigid, centralized structures that limit adaptability and lead to coordination failures such as redundancy, distraction, domination, and exploitation (Pan et al., 2025). This research proposes a Bayesian, game-theoretic framework in which agents probabilistically infer task capability and negotiate collaboration through Nash equilibrium dynamics, enabling hierarchical, self-organizing task allocation without centralized control. Capability, connection, and stability functions allow agents to adapt their interactions and the system to evolve under uncertainty, balancing exploration and exploitation through Bayesian updating. The framework is validated through theoretical formulation and simulated experiments, demonstrating improved coordination efficiency, adaptability, and robustness over existing multi-agent generative AI approaches.},
  volume      = {18},
  year        = {2025},
  additional_info = {Developed through discussions with Dr. [Sanju Menon](https://www.linkedin.com/in/sanjumenonp/)},
  preview      = {game.png}

}

@article{gaogui2024interactive,
  bibtex_show = {true},
  title       = {Interactive Visual Grounding of Ambiguous Natural Language Instructions},
  author      = {Gao, Gui},
  abstract    = {Natural language is the most accessible mode of human-robot interaction, yet its inherent ambiguity poses a major challenge for object manipulation tasks, where a robot must correctly infer human intent. This work introduces an interactive, attribute-guided disambiguation system that enables robots to recognize referential ambiguity and actively resolve it through targeted questions. The system combines object attribute classifiers, an information-entropy-based disambiguation algorithm, and open-ended language simulation and parsing modules. By identifying when and what to ask, the robot extracts the information needed to disambiguate instructions, improving the accuracy and reliability of human-robot interaction in tasks demanding precise communication.},
  volume      = {32},
  year        = {2024},
  additional_info = {Supervised by Prof. [Lee Wee Sun](https://scholar.google.com/citations?user=8PCrLgwAAAAJ&hl=en) and Dr. [Zhao Zirui](https://scholar.google.com/citations?user=sKs2OLUAAAAJ&hl=en)},
  preview      = {interactive.png}
}
